<Window x:Class="_7.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_7"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="700">
    <!--<Window.Resources>
        <local:User x:Key="medik"/>
    </Window.Resources>
    <Window.DataContext>
        <Binding Source="{StaticResource medik}"/>
    </Window.DataContext>-->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="215"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="220"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0" Grid.RowSpan="2">
            <StackPanel Orientation="Horizontal">
                <Label Content="Идентификатор"/>
                <TextBox Margin="5" Width="50" Text="{Binding Id,UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="Имя"/>
                <TextBox Name="Id_Doctor" Margin="5" Width="50" Text="{Binding name,UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="специализация"/>
                <ComboBox Width="120">
                    <Button Content="Терапевт"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="фамилия"/>
                <TextBox Margin="5" Width="50" Text="{Binding lastname,UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="Отчество"/>
                <TextBox Margin="5" Width="50" Text="{Binding Father,UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
 
            <StackPanel Orientation="Horizontal">
                <Label Content="Пароль"/>
                <PasswordBox Width="100" Margin="5" Text="{Binding password,UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="Подтверждение"/>
                <PasswordBox Width="100" Margin="5" Text="{Binding password,UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <Button Content="Добавить доктора" Click="Button_Click_1" />
            
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.Column="0">

            <Label Content="Для входа П введите ID и пароль"/>
            <TextBox Margin="5"/>
            <TextBox Margin="5"/>
            <Button Content="войти"/>
        </StackPanel>

        <StackPanel Grid.Column="0" Grid.Row="3">
            <StackPanel Orientation="Horizontal">
                <Label Content="Идентификатор"/>
                <TextBlock Margin="5" Width="50" Text="{Binding Id}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="Имя"/>
                <TextBlock Margin="5" Width="50" Text="{Binding name}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="специализация"/>
                <TextBlock Margin="5" Width="50" Text="{Binding spec}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="фамилия"/>
                <TextBlock Margin="5" Width="50" Text="{Binding lastname}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="Отчество"/>
                <TextBlock Margin="5" Width="50" Text="{Binding Father}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="Пароль"/>
                <TextBlock Width="100" Margin="5" Text="{Binding password}"/>
            </StackPanel>



        </StackPanel>

        <StackPanel Grid.Column="1" Grid.RowSpan="1" Orientation="Horizontal">
            <Label Content="ID:"/>
            <TextBox Width="100" Margin="5" Text="{Binding Id,UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="найти"/>
        </StackPanel>

        <StackPanel Grid.Column="2" Grid.RowSpan="2">
            <StackPanel Orientation="Horizontal">
                <Label Content="День рождения"/>
                <TextBox Margin="5" Width="50" Text="{Binding Id,UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="Имя"/>
                <TextBox Margin="5" Width="50" Text="{Binding Id,UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="последний доктор"/>
                <Label Content="последний доктор"/>

            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="фамилия"/>
                <TextBox Margin="5" Width="50" Text="{Binding Id,UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="Отчество"/>
                <TextBox Margin="5" Width="50" Text="{Binding Id,UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal">
                <Label Content="дата приема"/>
                <TextBox Margin="5" Width="50" Text="{Binding Id,UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="Диагноз"/>
                <TextBox Width="100" Margin="5" Text="{Binding password,UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="рекомендации"/>
                <TextBox Width="100" Margin="5" Text="{Binding password,UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <Button Content="добавить пациента" />

        </StackPanel>

        <StackPanel Grid.Column="2" Grid.Row="2" Grid.RowSpan="2">
            <Label Content="изменение данных о пациенте"/>
            <StackPanel Orientation="Horizontal">
                <Label Content="День рождения"/>
                <TextBox Margin="5" Width="50" Text="{Binding Id,UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="Имя"/>
                <TextBox Margin="5" Width="50" Text="{Binding Id,UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="последний доктор"/>
                <TextBox Margin="5" Width="50" Text="{Binding Id,UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="фамилия"/>
                <TextBox Margin="5" Width="50" Text="{Binding Id,UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="Отчество"/>
                <TextBox Margin="5" Width="50" Text="{Binding Id,UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="дата приема"/>
                <TextBox Margin="5" Width="50" Text="{Binding Id,UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="Диагноз"/>
                <TextBox Width="100" Margin="5" Text="{Binding password,UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="рекомендации"/>
                <TextBox Width="100" Margin="5" Text="{Binding password,UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <Button Content="сохранить новую информацию" />

        </StackPanel>

        <StackPanel Grid.Column="1" Grid.Row="1" Grid.RowSpan="3">
                <Label Content="День рождения"/>
                <TextBlock Margin="5" Width="50" Text="{Binding Id,UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Имя"/>
                <TextBlock Margin="5" Width="50" Text="{Binding Id,UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="последний доктор"/>
                <TextBlock Margin="5" Width="50" Text="{Binding Id,UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="фамилия"/>
                <TextBlock Margin="5" Width="50" Text="{Binding Id,UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Отчество"/>
                <TextBlock Margin="5" Width="50" Text="{Binding Id,UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="дата приема"/>
                <TextBlock Margin="5" Width="50" Text="{Binding Id,UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Диагноз"/>
                <TextBlock Width="100" Margin="5" Text="{Binding password,UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="рекомендации"/>
                <TextBlock Width="100" Margin="5" Text="{Binding password,UpdateSourceTrigger=PropertyChanged}"/>


        </StackPanel>

    </Grid>
</Window>
