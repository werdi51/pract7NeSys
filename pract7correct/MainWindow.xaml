<Window x:Class="pract7correct.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pract7correct"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <local:User x:Key="CurrentUser"/>
    </Window.Resources>
    <Window.DataContext>
        <Binding Source="{StaticResource CurrentUser}"/>
    </Window.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <StackPanel>
            <Label Content="ID"/>
            <Label Content="Имя"/>
            <Label Content="Адрес электронной почты"/>
            <Label Content="Возраст"/>
        </StackPanel>

        <StackPanel Grid.Column="1">
            <TextBox Margin="5" Text="{Binding Id,UpdateSourceTrigger=PropertyChanged}"/>
            <TextBox Margin="5" Text="{Binding Name ,UpdateSourceTrigger=PropertyChanged}"/>
            <TextBox Margin="5" Text="{Binding Email,UpdateSourceTrigger=PropertyChanged}"/>
            <TextBox Margin="5" Text="{Binding Age,UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <StackPanel Grid.Column="2" Grid.Row="0" Grid.RowSpan="4">
            <TextBlock Text="Идентификатор:"/>
            <TextBlock Text="{Binding Id}"/>
            <TextBlock Text="Имя:"/>
            <TextBlock Text="{Binding Name}"/>
            <TextBlock Text="Адрес электронной почты:"/>
            <TextBlock Text="{Binding Email}"/>
            <TextBlock Text="Возраст:"/>
            <TextBlock Text="{Binding Age}"/>
            <Button Content="Сбросить объект" Click="ResetUser"/>
        </StackPanel>

    </Grid>
</Window>
